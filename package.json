{
  "name": "feishu-md",
  "version": "0.6.0",
  "type": "module",
  "description": "飞书文档 Markdown 双向同步命令行工具",
  "keywords": [
    "feishu",
    "lark",
    "markdown",
    "cli",
    "sync",
    "飞书",
    "知识库"
  ],
  "license": "MIT",
  "author": "RunningCoderLee",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RunningCoderLee/feishu-md.git"
  },
  "homepage": "https://github.com/RunningCoderLee/feishu-md#readme",
  "bin": {
    "feishu-md": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -b",
    "build:bin": "bun build src/index.ts --compile --outfile dist-bin/feishu-md && rm -f .*.bun-build",
    "start": "node dist/index.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,json}": "biome check --write --no-errors-on-unmatched"
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.33.0",
    "commander": "^14.0.3",
    "inquirer": "^13.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.3.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.27.0",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=16"
  }
}

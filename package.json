{
  "name": "feishu-md",
  "version": "0.1.1",
  "type": "module",
  "description": "飞书文档 Markdown 双向同步命令行工具",
  "bin": {
    "feishu-md": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -b",
    "build:bin": "bun build src/index.ts --compile --outfile dist-bin/feishu-md && rm -f .*.bun-build",
    "start": "node dist/index.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.33.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "inquirer": "^13.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^22.10.5",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=16"
  }
}
